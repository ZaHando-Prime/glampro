# ============================================================
# Glam Pro Beauty Assistant – Environment Variables Template
# Copy this file to .env and fill in the values.
# ============================================================

# --- LLM ---
# Absolute or relative path to the GGUF model file.
# Download: https://huggingface.co/bartowski/Llama-3.2-3B-Instruct-GGUF
# Recommended file: Llama-3.2-3B-Instruct-Q4_K_M.gguf (~2 GB)
MODEL_PATH=./models/Llama-3.2-3B-Instruct-Q4_K_M.gguf

LLM_N_CTX=4096

LLM_N_THREADS=8

LLM_MAX_TOKENS=512

LLM_TEMPERATURE=0.7

LLM_TOP_P=0.95


ADMIN_API_KEY=change-me-in-production


CHROMA_PATH=./chroma_data


DATA_DIR=./data
